<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý người dùng - Auto Quiz</title>
  <link rel="stylesheet" href="/css/admin.css">
  <style>
    /* Thêm style cho bảng user */
    .user-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: #1a1a1a;
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
    }
    
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    
    .status-active {
      background: #d4edda;
      color: #155724;
    }
    
    .status-locked {
      background: #f8d7da;
      color: #721c24;
    }
    
    .action-buttons {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    
    .btn-small {
      padding: 4px 10px;
      font-size: 12px;
      border-radius: 4px;
      cursor: pointer;
      border: none;
    }
    
    .btn-lock {
      background: #ffc107;
      color: #333;
    }
    
    .btn-unlock {
      background: #28a745;
      color: white;
    }
    
    .btn-reset {
      background: #17a2b8;
      color: white;
    }
    
    .btn-delete-user {
      background: #dc3545;
      color: white;
    }
    
    .search-box {
      margin-bottom: 20px;
      display: flex;
      gap: 10px;
    }
    
    .search-box input {
      flex: 1;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <div class="admin-header">
    <h1>Auto Quiz <span>| Quản lý người dùng</span></h1>
  </div>

  <main class="admin-container">
    <!-- Thống kê nhanh -->
    <div class="stats-grid">
      <div class="stat-card">
        <h3>TỔNG NGƯỜI DÙNG</h3>
        <div class="stat-number" id="totalUsers">0</div>
      </div>
      <div class="stat-card">
        <h3>ĐANG HOẠT ĐỘNG</h3>
        <div class="stat-number" id="activeUsers">0</div>
      </div>
      <div class="stat-card">
        <h3>ĐÃ KHÓA</h3>
        <div class="stat-number" id="lockedUsers">0</div>
      </div>
    </div>

    <!-- Quản lý user -->
    <div class="comments-section">
      <h2 class="section-title">👥 Danh sách người dùng</h2>
      
      <div class="search-box">
        <input type="text" id="searchInput" placeholder="🔍 Tìm kiếm theo tên hoặc email...">
      </div>
      
      <div style="overflow-x: auto;">
        <table class="comments-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Tên đăng nhập</th>
              <th>Email</th>
              <th>Trạng thái</th>
              <th>Ngày đăng ký</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="userTableBody">
            <tr><td colspan="6" style="text-align: center;">Đang tải...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div style="background: white; border-radius: 12px; padding: 1rem; text-align: center; border: 1px solid #eee;">
      <a href="/admin" style="color: #1a1a1a;">← Quay lại trang chính</a>
    </div>
  </main>

  <script>
    let usersData = [];
    
    // Lấy danh sách user
    async function loadUsers() {
      try {
        const response = await fetch('/api/users/list');
        const users = await response.json();
        usersData = users;
        
        // Cập nhật thống kê
        const activeCount = users.filter(u => !u.is_locked).length;
        const lockedCount = users.filter(u => u.is_locked).length;
        
        document.getElementById('totalUsers').innerText = users.length;
        document.getElementById('activeUsers').innerText = activeCount;
        document.getElementById('lockedUsers').innerText = lockedCount;
        
        renderUsers(users);
      } catch (err) {
        document.getElementById('userTableBody').innerHTML = '<tr><td colspan="6" style="text-align: center; color: red;">Lỗi tải dữ liệu</td></tr>';
      }
    }
    
    // Render danh sách user
    function renderUsers(users) {
      const tbody = document.getElementById('userTableBody');
      
      if (users.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center;">Không có người dùng nào</td></tr>';
        return;
      }
      
      tbody.innerHTML = users.map(user => `
        <tr data-id="${user.id}">
          <td>${user.id}</td>
          <td><strong>${escapeHtml(user.username)}</strong></td>
          <td>${escapeHtml(user.email)}</td>
          <td>
            <span class="status-badge ${user.is_locked ? 'status-locked' : 'status-active'}">
              ${user.is_locked ? '🔒 Đã khóa' : '✅ Hoạt động'}
            </span>
          </td>
          <td>${new Date(user.created_at).toLocaleDateString('vi-VN')}</td>
          <td>
            <div class="action-buttons">
              <button class="btn-small ${user.is_locked ? 'btn-unlock' : 'btn-lock'}" 
                      onclick="toggleLock(${user.id}, ${user.is_locked})">
                ${user.is_locked ? '🔓 Mở khóa' : '🔒 Khóa'}
              </button>
              <button class="btn-small btn-reset" onclick="resetPassword(${user.id}, '${escapeHtml(user.username)}')">
                🔑 Reset pass
              </button>
              <button class="btn-small btn-delete-user" onclick="deleteUser(${user.id}, '${escapeHtml(user.username)}')">
                🗑️ Xóa
              </button>
            </div>
          </td>
        </tr>
      `).join('');
    }
    
    // Tìm kiếm
    document.getElementById('searchInput').addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase();
      const filtered = usersData.filter(user => 
        user.username.toLowerCase().includes(searchTerm) || 
        user.email.toLowerCase().includes(searchTerm)
      );
      renderUsers(filtered);
    });
    
    // Khóa/Mở khóa user
    async function toggleLock(userId, currentStatus) {
      const action = currentStatus ? 'mở khóa' : 'khóa';
      if (confirm(`Bạn có chắc muốn ${action} tài khoản này?`)) {
        try {
          const response = await fetch(`/api/users/toggle-lock/${userId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' }
          });
          const result = await response.json();
          
          if (result.success) {
            alert(result.message);
            loadUsers(); // Reload lại danh sách
          } else {
            alert('Lỗi: ' + result.error);
          }
        } catch (err) {
          alert('Lỗi kết nối');
        }
      }
    }
    
    // Reset password
    async function resetPassword(userId, username) {
      if (confirm(`Reset mật khẩu cho user "${username}" về mặc định "123456"?`)) {
        try {
          const response = await fetch(`/api/users/reset-password/${userId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });
          const result = await response.json();
          
          if (result.success) {
            alert(result.message);
          } else {
            alert('Lỗi: ' + result.error);
          }
        } catch (err) {
          alert('Lỗi kết nối');
        }
      }
    }
    
    // Xóa user
    async function deleteUser(userId, username) {
      if (confirm(`⚠️ CẢNH BÁO: Bạn có chắc muốn XÓA VĨNH VIỄN user "${username}"?\nHành động này không thể hoàn tác!`)) {
        try {
          const response = await fetch(`/api/users/delete/${userId}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          const result = await response.json();
          
          if (result.success) {
            alert(result.message);
            loadUsers(); // Reload lại danh sách
          } else {
            alert('Lỗi: ' + result.error);
          }
        } catch (err) {
          alert('Lỗi kết nối');
        }
      }
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    // Load khi trang mở
    loadUsers();
  </script>
</body>
</html>